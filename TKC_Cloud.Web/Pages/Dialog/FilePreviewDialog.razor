@inject IHttpClientFactory ClientFactory

<MudDialog>
    <DialogContent>

        @if (IsImage)
        {
            <img src="@PreviewUrl" style="max-width:100%; max-height:80vh;" />
        }
        else if (IsPdf)
        {
            <iframe src="@PreviewUrl" width="100%" height="600px"></iframe>
        }
        else if (IsVideo)
        {
            <video controls width="100%">
                <source src="@PreviewUrl" />
            </video>
        }
        else if (IsAudio)
        {
            <audio controls>
                <source src="@PreviewUrl" />
            </audio>
        }
        else
        {
            <MudText>Preview nicht verfügbar.</MudText>
        }

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public FileEntry File { get; set; } = default!;

    private HttpClient? api;
    private string PreviewUrl = string.Empty;

    private bool IsImage;
    private bool IsPdf;
    private bool IsVideo;
    private bool IsAudio;

    protected override async Task OnParametersSetAsync()
    {
        api = ClientFactory.CreateClient("API");

        var response = await api.PostAsync($"api/files/{File.Id}/create-access", null);

        var data = await response.Content.ReadFromJsonAsync<TokenResponse>();

        PreviewUrl = $"{api.BaseAddress}api/files/preview?access={data!.Token}";

        var type = File.ContentType?.ToLower() ?? "";

        IsImage = type.StartsWith("image/");
        IsPdf = type.StartsWith("application/pdf");
        IsVideo = type.StartsWith("video/");
        IsAudio = type.StartsWith("audio/");        
    }

    private void Close()
    {
        MudDialog.Close();
    }

    // Helpers
    public class TokenResponse
    {
        public string Token { get; set; } = string.Empty;
    }
}